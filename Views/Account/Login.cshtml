@model TicketSystem.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<!-- Giriş formu — Data Annotations ile istemci tarafı doğrulama otomatik çalışır -->
<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white text-center py-3">
                <h4 class="mb-0"><i class="bi bi-box-arrow-in-right"></i> Giriş Yap</h4>
            </div>
            <div class="card-body p-4">

                <!-- asp-action: formun gideceği controller action'ı -->
                <!-- asp-antiforgery: gizli CSRF token alanı ekler -->
                <form asp-action="Login" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Model bazlı hata mesajları (giriş hatalıysa buraya yazılır) -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:none"></div>
                    @if (ViewData.ModelState.ErrorCount > 0)
                    {
                        <div class="alert alert-danger">
                            <div asp-validation-summary="ModelOnly"></div>
                        </div>
                    }

                    <!-- E-posta alanı -->
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@mail.com" />
                        <!-- asp-validation-for → o alana ait hata mesajını gösterir -->
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- Şifre alanı -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" placeholder="••••••" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <!-- Beni hatırla checkbox'ı -->
                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Beni Hatırla</label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                    </button>
                </form>

                <hr />
                <div class="text-center">
                    <small>Hesabınız yok mu?
                        <a asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- jQuery Unobtrusive Validation → Data Annotation kurallarını client-side'da çalıştırır -->
    <partial name="_ValidationScriptsPartial" />
}
